// ============================================================================
// Fashion-SaaS Financial & Ops Engine — Prisma Schema
// Database: PostgreSQL (Strict Relational Integrity)
// Principle: No deletions, only reversals. Full audit trail.
// ============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// 1. TENANCY & AUTH
// ============================================================================

model Tenant {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  currency  String   @default("EGP")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users              User[]
  products           Product[]
  rawMaterials       RawMaterial[]
  vendors            Vendor[]
  productionOrders   ProductionOrder[]
  salesOrders        SalesOrder[]
  shippingProviders  ShippingProvider[]
  reconciliations    ShippingReconciliation[]
  exchangeRates      ExchangeRate[]
  auditLogs          AuditLog[]

  @@map("tenants")
}

model User {
  id           String   @id @default(uuid())
  tenantId     String
  email        String
  passwordHash String
  fullName     String
  role         UserRole @default(STAFF)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant    Tenant     @relation(fields: [tenantId], references: [id])
  auditLogs AuditLog[]

  @@unique([tenantId, email])
  @@map("users")
}

enum UserRole {
  OWNER
  ADMIN
  ACCOUNTANT
  STAFF
}

// ============================================================================
// 2. RAW MATERIALS & INVENTORY (AVCO Engine)
// ============================================================================

model RawMaterial {
  id          String          @id @default(uuid())
  tenantId    String
  name        String
  sku         String
  unit        MaterialUnit
  avgCost     Decimal         @default(0) @db.Decimal(12, 4)
  totalQty    Decimal         @default(0) @db.Decimal(12, 4)
  totalValue  Decimal         @default(0) @db.Decimal(14, 4)
  minStock    Decimal         @default(0) @db.Decimal(12, 4)
  currency    String          @default("EGP")
  isActive    Boolean         @default(true)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  tenant         Tenant              @relation(fields: [tenantId], references: [id])
  ledgerEntries  InventoryLedger[]
  bomItems       BomItem[]

  @@unique([tenantId, sku])
  @@map("raw_materials")
}

enum MaterialUnit {
  METER
  KILOGRAM
  PIECE
  ROLL
  YARD
}

/// Every purchase, consumption, or adjustment is an immutable ledger entry.
model InventoryLedger {
  id              String        @id @default(uuid())
  rawMaterialId   String
  type            LedgerType
  qty             Decimal       @db.Decimal(12, 4)
  unitCost        Decimal       @db.Decimal(12, 4)
  totalCost       Decimal       @db.Decimal(14, 4)
  runningAvgCost  Decimal       @db.Decimal(12, 4)
  runningQty      Decimal       @db.Decimal(12, 4)
  runningValue    Decimal       @db.Decimal(14, 4)
  landedCost      Decimal       @default(0) @db.Decimal(14, 4)
  reference       String?
  notes           String?
  createdAt       DateTime      @default(now())

  rawMaterial RawMaterial @relation(fields: [rawMaterialId], references: [id])

  @@index([rawMaterialId, createdAt])
  @@map("inventory_ledger")
}

enum LedgerType {
  INBOUND          // Purchase / received goods
  OUTBOUND         // Consumed by production
  ADJUSTMENT_PLUS  // Manual adjustment up
  ADJUSTMENT_MINUS // Manual adjustment down
  REVERSAL         // Reversal of a previous entry
  RETURN_IN        // Returned from production / customer
}

// ============================================================================
// 3. PRODUCT MATRIX & BOM
// ============================================================================

model Product {
  id          String   @id @default(uuid())
  tenantId    String
  name        String
  baseSku     String
  description String?
  category    String?
  isBundle    Boolean  @default(false)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant    Tenant          @relation(fields: [tenantId], references: [id])
  variants  ProductVariant[]
  bundleItems BundleItem[]  @relation("BundleParent")

  @@unique([tenantId, baseSku])
  @@map("products")
}

model ProductVariant {
  id            String   @id @default(uuid())
  productId     String
  sku           String
  color         String?
  size          String?
  fit           String?
  sellingPrice  Decimal  @default(0) @db.Decimal(12, 2)
  standardCost  Decimal  @default(0) @db.Decimal(12, 4)
  stockQty      Int      @default(0)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  product            Product               @relation(fields: [productId], references: [id])
  bomItems           BomItem[]
  productionItems    ProductionOrderItem[]
  salesOrderItems    SalesOrderItem[]
  bundleComponents   BundleItem[]          @relation("BundleComponent")

  @@unique([productId, sku])
  @@map("product_variants")
}

/// Bill of Materials: links a variant to its raw-material recipe.
model BomItem {
  id              String  @id @default(uuid())
  variantId       String
  rawMaterialId   String
  qtyRequired     Decimal @db.Decimal(10, 4)
  notes           String?

  variant     ProductVariant @relation(fields: [variantId], references: [id])
  rawMaterial RawMaterial    @relation(fields: [rawMaterialId], references: [id])

  @@unique([variantId, rawMaterialId])
  @@map("bom_items")
}

/// Virtual bundles — selling a "set" that deducts individual variant stock.
model BundleItem {
  id              String  @id @default(uuid())
  bundleProductId String
  componentVariantId String
  qty             Int     @default(1)

  bundleProduct    Product        @relation("BundleParent",   fields: [bundleProductId],    references: [id])
  componentVariant ProductVariant @relation("BundleComponent", fields: [componentVariantId], references: [id])

  @@unique([bundleProductId, componentVariantId])
  @@map("bundle_items")
}

// ============================================================================
// 4. VENDORS & SUB-CONTRACTING
// ============================================================================

model Vendor {
  id         String     @id @default(uuid())
  tenantId   String
  name       String
  type       VendorType
  phone      String?
  address    String?
  balance    Decimal    @default(0) @db.Decimal(14, 2)
  currency   String     @default("EGP")
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  tenant            Tenant              @relation(fields: [tenantId], references: [id])
  ledgerEntries     VendorLedger[]
  productionOrders  ProductionOrder[]

  @@map("vendors")
}

enum VendorType {
  FABRIC_SUPPLIER
  CUTTING_WORKSHOP
  SEWING_WORKSHOP
  ACCESSORIES_SUPPLIER
  PACKAGING_SUPPLIER
  OTHER
}

/// Immutable financial ledger for each vendor.
model VendorLedger {
  id          String           @id @default(uuid())
  vendorId    String
  type        VendorTxnType
  amount      Decimal          @db.Decimal(14, 2)
  reference   String?
  notes       String?
  createdAt   DateTime         @default(now())

  vendor Vendor @relation(fields: [vendorId], references: [id])

  @@index([vendorId, createdAt])
  @@map("vendor_ledger")
}

enum VendorTxnType {
  INVOICE       // Vendor charged us
  PAYMENT       // We paid vendor
  DEBIT_NOTE    // Adjustment in our favor
  CREDIT_NOTE   // Adjustment in vendor favor
  REVERSAL
}

// ============================================================================
// 5. PRODUCTION LIFECYCLE & WASTAGE
// ============================================================================

model ProductionOrder {
  id              String              @id @default(uuid())
  tenantId        String
  orderNumber     String
  vendorId        String?
  status          ProductionStatus    @default(DRAFT)
  laborCostPerUnit Decimal            @default(0) @db.Decimal(10, 2)
  packagingCostPerUnit Decimal        @default(0) @db.Decimal(10, 2)
  notes           String?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  tenant  Tenant  @relation(fields: [tenantId], references: [id])
  vendor  Vendor? @relation(fields: [vendorId], references: [id])
  items   ProductionOrderItem[]
  wastageRecords WastageRecord[]

  @@unique([tenantId, orderNumber])
  @@map("production_orders")
}

enum ProductionStatus {
  DRAFT
  FABRIC_RESERVED
  ISSUED_TO_FACTORY
  QC_PENDING
  STOCKED
  CANCELLED
}

model ProductionOrderItem {
  id                String  @id @default(uuid())
  productionOrderId String
  variantId         String
  qtyOrdered        Int
  qtyReceived       Int     @default(0)
  qtyDefective      Int     @default(0)

  productionOrder ProductionOrder @relation(fields: [productionOrderId], references: [id])
  variant         ProductVariant  @relation(fields: [variantId], references: [id])

  @@map("production_order_items")
}

model WastageRecord {
  id                String   @id @default(uuid())
  productionOrderId String
  theoreticalUsage  Decimal  @db.Decimal(12, 4)
  actualUsage       Decimal  @db.Decimal(12, 4)
  efficiencyPct     Decimal  @db.Decimal(5, 2)
  notes             String?
  createdAt         DateTime @default(now())

  productionOrder ProductionOrder @relation(fields: [productionOrderId], references: [id])

  @@map("wastage_records")
}

// ============================================================================
// 6. SALES ORDERS & RETURNS
// ============================================================================

model SalesOrder {
  id                String       @id @default(uuid())
  tenantId          String
  orderNumber       String
  customerName      String?
  customerPhone     String?
  customerAddress   String?
  status            OrderStatus  @default(PENDING)
  totalAmount       Decimal      @db.Decimal(14, 2)
  codAmount         Decimal      @default(0) @db.Decimal(14, 2)
  shippingProviderId String?
  trackingNumber    String?
  shippingCost      Decimal      @default(0) @db.Decimal(10, 2)
  adSpendAllocation Decimal      @default(0) @db.Decimal(10, 2)
  notes             String?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  tenant           Tenant            @relation(fields: [tenantId], references: [id])
  shippingProvider ShippingProvider? @relation(fields: [shippingProviderId], references: [id])
  items            SalesOrderItem[]
  returnRecord     ReturnRecord?

  @@unique([tenantId, orderNumber])
  @@index([status])
  @@map("sales_orders")
}

enum OrderStatus {
  PENDING
  PROCESSING
  SHIPPED
  DELIVERED
  COLLECTED      // Cash collected from shipping provider
  RETURNED
  CANCELLED
}

model SalesOrderItem {
  id           String  @id @default(uuid())
  salesOrderId String
  variantId    String
  qty          Int
  unitPrice    Decimal @db.Decimal(12, 2)
  unitCost     Decimal @db.Decimal(12, 4)

  salesOrder SalesOrder     @relation(fields: [salesOrderId], references: [id])
  variant    ProductVariant @relation(fields: [variantId], references: [id])

  @@map("sales_order_items")
}

model ReturnRecord {
  id                String  @id @default(uuid())
  salesOrderId      String  @unique
  reason            String?
  isProductIntact   Boolean @default(true)
  forwardShipping   Decimal @db.Decimal(10, 2)
  returnShipping    Decimal @db.Decimal(10, 2)
  refurbishmentCost Decimal @default(0) @db.Decimal(10, 2)
  totalLoss         Decimal @db.Decimal(12, 2)
  returnedToStock   Boolean @default(false)
  createdAt         DateTime @default(now())

  salesOrder SalesOrder @relation(fields: [salesOrderId], references: [id])

  @@map("return_records")
}

// ============================================================================
// 7. SHIPPING RECONCILIATION
// ============================================================================

model ShippingProvider {
  id          String   @id @default(uuid())
  tenantId    String
  name        String
  code        String
  agreedRate  Decimal  @default(0) @db.Decimal(10, 2)
  walletBalance Decimal @default(0) @db.Decimal(14, 2)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant          Tenant                   @relation(fields: [tenantId], references: [id])
  orders          SalesOrder[]
  reconciliations ShippingReconciliation[]

  @@unique([tenantId, code])
  @@map("shipping_providers")
}

model ShippingReconciliation {
  id                 String             @id @default(uuid())
  tenantId           String
  shippingProviderId String
  fileName           String
  uploadedAt         DateTime           @default(now())
  totalRows          Int                @default(0)
  matchedCount       Int                @default(0)
  discrepancyCount   Int                @default(0)
  missingCount       Int                @default(0)
  netPayout          Decimal            @default(0) @db.Decimal(14, 2)
  status             ReconciliationStatus @default(PENDING)

  tenant           Tenant                          @relation(fields: [tenantId], references: [id])
  shippingProvider ShippingProvider                @relation(fields: [shippingProviderId], references: [id])
  rows             ShippingReconciliationRow[]

  @@map("shipping_reconciliations")
}

enum ReconciliationStatus {
  PENDING
  PROCESSING
  COMPLETED
  REVIEWED
}

model ShippingReconciliationRow {
  id                  String          @id @default(uuid())
  reconciliationId    String
  orderNumber         String
  expectedCod         Decimal         @db.Decimal(12, 2)
  actualCod           Decimal         @db.Decimal(12, 2)
  expectedShippingFee Decimal         @db.Decimal(10, 2)
  actualShippingFee   Decimal         @db.Decimal(10, 2)
  returnFee           Decimal         @default(0) @db.Decimal(10, 2)
  flag                ReconcileFlag

  reconciliation ShippingReconciliation @relation(fields: [reconciliationId], references: [id])

  @@map("shipping_reconciliation_rows")
}

enum ReconcileFlag {
  MATCHED
  DISCREPANCY
  HIDDEN_FEE
  MISSING
}

// ============================================================================
// 8. MULTI-CURRENCY
// ============================================================================

model ExchangeRate {
  id         String   @id @default(uuid())
  tenantId   String
  fromCurrency String
  toCurrency   String
  rate       Decimal  @db.Decimal(12, 6)
  isManual   Boolean  @default(false)
  effectiveAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId, fromCurrency, toCurrency])
  @@map("exchange_rates")
}

// ============================================================================
// 9. AUDIT TRAIL (Immutable)
// ============================================================================

model AuditLog {
  id         String   @id @default(uuid())
  tenantId   String
  userId     String?
  tableName  String
  recordId   String
  action     AuditAction
  oldValues  Json?
  newValues  Json?
  ipAddress  String?
  createdAt  DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])
  user   User?  @relation(fields: [userId], references: [id])

  @@index([tenantId, tableName, recordId])
  @@index([tenantId, createdAt])
  @@map("audit_logs")
}

enum AuditAction {
  CREATE
  UPDATE
  REVERSE
}
